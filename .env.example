# Supabase (Auth) – from Supabase Dashboard: Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# Required for profile insert + auto-confirm signup (testing without email verification)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Testing only: skip email verification – user can log in right after signup. Requires SUPABASE_SERVICE_ROLE_KEY.
# SIGNUP_AUTO_CONFIRM_EMAIL=true

OPENAI_API_KEY=your-openai-api-key

# Where to redirect users after email verification (login page)
FRONTEND_URL=http://localhost:3000
